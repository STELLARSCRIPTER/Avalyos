# AVALYOS Environment Variables

# FastAPI Backend Configuration
# Port for FastAPI server (default: 8000)
AVAL_PORT=8000

# Q# Configuration
# Maximum number of operations in the Q# execution queue (default: 64)
QSHARP_QUEUE_MAX=64

# Rate Limiting Configuration
# Maximum API calls per minute per API key (default: 60)
AVAL_RATE_PER_MIN=60

# Authentication Configuration
# API key for accessing FastAPI endpoints (optional, can be omitted)
AVAL_API_KEY=your_secret_api_key_here

# PostgreSQL Database Configuration
# Connection string for PostgreSQL database
# Format: postgresql://username:password@host:port/database
DATABASE_URL=postgresql://avalyos:avalyos_password@localhost:5432/avalyos_db

# MongoDB Configuration
# Connection string for MongoDB database
# Format: mongodb://username:password@host:port/database
# For local MongoDB without authentication: mongodb://localhost:27017/avalyos_db
MONGODB_URI=mongodb://avalyos:avalyos_password@localhost:27017/avalyos_db

# Streamlit Configuration
STREAMLIT_SERVER_PORT=8501
STREAMLIT_SERVER_HEADLESS=true
STREAMLIT_CLIENT_SHOW_ERROR_DETAILS=true

# Application Configuration
# Data file location (relative to project root)
COMPANIES_DATA_FILE=companies.json

# Logging Configuration
LOG_LEVEL=INFO
LOG_FILE=logs/avalyos.log
